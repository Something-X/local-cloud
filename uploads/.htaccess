# Blokir eksekusi script di folder uploads
# Semua file PHP/script akan ditampilkan sebagai teks biasa
php_flag engine off

# Blokir akses ke file tersembunyi (dotfiles)
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Tambahan: set header keamanan untuk file yang di-serve
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
</IfModule>
